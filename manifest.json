{
  "manifest_version": 3,
  "name": "ChatGPT PDF Preprocessor",
  "version": "1.0.0",
  "description": "Intercept PDF uploads on chatgpt.com so users can remove pages and compress files before upload.",
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*.js",
        "ui/*.js",
        "ui/*.css",
        "vendor/*"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ]
}
